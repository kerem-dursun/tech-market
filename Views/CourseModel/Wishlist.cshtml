@model IEnumerable<tech_market.Models.WishlistItem>

@{
    ViewData["Title"] = "My Wishlist";
}

<h1 class="text-dark mb-4">My Wishlist</h1>

@if (!Model.Any())
{
    <div class="card p-5 text-center shadow">
        <div class="mb-3">
            <i class="bi bi-heart text-muted" style="font-size: 4rem;"></i>
        </div>
        <h3 class="text-dark">Your wishlist is empty</h3>
        <p class="text-muted">Save items you like to find them later.</p>
        <div class="mt-3">
            <a asp-action="Store" class="btn btn-primary">Discover Products</a>
        </div>
    </div>
}
else
{
    <div class="card shadow">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4">Product</th>
                        <th>Manufacturer</th>
                        <th>Price</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="d-flex align-items-center">
                                    @if (!string.IsNullOrEmpty(item.Product.ImageUrl))
                                    {
                                        <img src="@item.Product.ImageUrl" alt="@item.Product.Name" class="rounded me-3" style="width: 60px; height: 60px; object-fit: contain; background: white;">
                                    }
                                    <div>
                                        <div class="fw-bold">@item.Product.Name</div>
                                        <small class="text-muted">In stock</small>
                                    </div>
                                </div>
                            </td>
                            <td><span class="badge bg-secondary">@item.Product.Manufacturer</span></td>
                            <td class="fw-bold text-primary">@item.Product.Price $</td>
                            <td class="text-end pe-4">
                                <div class="d-flex justify-content-end gap-2">
                                    <form asp-action="AddToCart" method="post">
                                        <input type="hidden" name="productId" value="@item.Product.Id" />
                                        <input type="hidden" name="quantity" value="1" />
                                        <button type="submit" class="btn btn-sm btn-success">
                                            <i class="bi bi-cart-plus"></i> Add to Cart
                                        </button>
                                    </form>
                                    <form asp-action="RemoveFromWishlist" method="post">
                                        <input type="hidden" name="wishlistItemId" value="@item.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger">
                                            <i class="bi bi-x-lg"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

<div class="mt-4">
    <a asp-action="Store" class="btn btn-outline-light">
        <i class="bi bi-arrow-left"></i> Back to Store
    </a>
</div>