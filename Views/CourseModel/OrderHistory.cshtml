@model IEnumerable<tech_market.Models.Order>

@{
    ViewData["Title"] = "Order History";
}

<h1>My Purchase History</h1>

@if (!Model.Any())
{
    <div class="alert alert-info">You haven't placed any orders yet.</div>
}
else
{
    foreach (var order in Model)
    {
        <div class="card mb-4">
            <div class="card-header bg-light d-flex justify-content-between align-items-center">
                <div>
                    <strong>Order ID:</strong> #@order.Id |
                    <strong>Date:</strong> @order.OrderDate.ToString("dd.MM.yyyy HH:mm")
                </div>
                <div>
                    <span class="badge bg-success fs-6">Total: @order.TotalAmount $</span>
                </div>
            </div>
            <div class="card-body">
                <table class="table table-sm table-borderless mb-0">
                    <thead>
                        <tr>
                            <th>Product</th>
                            <th>Manufacturer</th>
                            <th>Quantity</th>
                            <th>Unit Price</th>
                            <th>Total</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in order.OrderItems)
                        {
                            <tr>
                                <td>@item.Product.Name</td>
                                <td>@item.Product.Manufacturer</td>
                                <td>@item.Quantity</td>
                                <td>@item.UnitPrice $</td>
                                <td>@(item.UnitPrice * item.Quantity) $</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
}

<p class="mt-3">
    <a asp-action="Store" class="btn btn-secondary">Back to Store</a>
</p>