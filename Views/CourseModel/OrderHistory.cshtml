@model IEnumerable<tech_market.Models.Order>

@{
    ViewData["Title"] = "Order History";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="text-dark">Purchase History</h1>
    <a asp-action="Store" class="btn btn-outline-info btn-sm">
        <i class="bi bi-shop"></i> Back to Store
    </a>
</div>

@if (!Model.Any())
{
    <div class="card p-5 text-center shadow">
        <div class="mb-3">
            <i class="bi bi-receipt text-muted" style="font-size: 4rem;"></i>
        </div>
        <h3 class="text-dark">No orders found</h3>
        <p class="text-muted">You haven't placed any orders yet.</p>
        <div class="mt-3">
            <a asp-action="Store" class="btn btn-primary">Start Shopping</a>
        </div>
    </div>
}
else
{
    foreach (var order in Model)
    {
        <div class="card mb-4 shadow-sm border-0 overflow-hidden">
            <div class="card-header bg-light d-flex justify-content-between align-items-center py-3 border-bottom">
                <div>
                    <span class="text-muted small d-block">ORDER PLACED</span>
                    <span class="fw-bold text-dark">@order.OrderDate.ToString("dd MMM yyyy HH:mm")</span>
                </div>
                <div>
                    <span class="text-muted small d-block">TOTAL AMOUNT</span>
                    <span class="fw-bold text-primary">@order.TotalAmount $</span>
                </div>
                <div>
                    <span class="text-muted small d-block">ORDER #</span>
                    <span class="fw-bold text-dark">@order.Id</span>
                </div>
                <div>
                    <span class="badge bg-success rounded-pill px-3">Completed</span>
                </div>
            </div>
            <div class="card-body bg-light text-dark p-0">
                <div class="table-responsive">
                    <table class="table table-borderless align-middle mb-0">
                        <thead class="bg-white border-bottom text-muted small">
                            <tr>
                                <th class="ps-4">PRODUCT</th>
                                <th>MANUFACTURER</th>
                                <th>QUANTITY</th>
                                <th class="text-end pe-4">UNIT PRICE</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in order.OrderItems)
                            {
                                <tr>
                                    <td class="ps-4 py-3">
                                        <div class="fw-bold text-primary">@item.Product.Name</div>
                                    </td>
                                    <td><span class="badge bg-secondary">@item.Product.Manufacturer</span></td>
                                    <td>@item.Quantity</td>
                                    <td class="text-end pe-4">@item.UnitPrice $</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
}