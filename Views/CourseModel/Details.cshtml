@model tech_market.Models.Product

@{
    ViewData["Title"] = "Product Details";
}

<div class="row justify-content-center">
    <div class="col-md-10">
        <div class="card shadow-lg border-0">
            <div class="row g-0">
                <div class="col-md-5 bg-white d-flex align-items-center justify-content-center p-4 rounded-start">
                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                    {
                        <img src="@Model.ImageUrl" alt="@Model.Name" class="img-fluid" style="max-height: 400px; object-fit: contain;" />
                    }
                    else
                    {
                        <div class="text-muted text-center">
                            <i class="bi bi-image" style="font-size: 5rem;"></i>
                            <p>No Image Available</p>
                        </div>
                    }
                </div>
                <div class="col-md-7">
                    <div class="card-body p-5">
                        <nav aria-label="breadcrumb" class="mb-3">
                            <ol class="breadcrumb">
                                <li class="breadcrumb-item"><a asp-action="Index">Products</a></li>
                                <li class="breadcrumb-item active" aria-current="page">Details</li>
                            </ol>
                        </nav>

                        <h1 class="display-5 fw-bold mb-2">@Model.Name</h1>
                        <span class="badge bg-primary mb-4">@Model.Manufacturer</span>

                        <div class="mb-4">
                            <h5 class="text-muted fw-bold">Description</h5>
                            <p class="lead">@Model.Description</p>
                        </div>

                        <div class="row mb-4 g-3">
                            <div class="col-6">
                                <div class="p-3 border rounded bg-light">
                                    <span class="text-muted small d-block">PRICE</span>
                                    <span class="h3 text-primary">@Model.Price $</span>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="p-3 border rounded bg-light">
                                    <span class="text-muted small d-block">STOCK LEVEL</span>
                                    <span class="h3 @(Model.StockQuantity > 0 ? "text-success" : "text-danger")">
                                        @Model.StockQuantity
                                    </span>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex gap-3 mt-5">
                            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning btn-lg px-5">
                                <i class="bi bi-pencil-square"></i> Edit
                            </a>
                            <a asp-action="Index" class="btn btn-outline-secondary btn-lg px-4">
                                Back to List
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>