@model IEnumerable<tech_market.Models.CartItem>

@{
    ViewData["Title"] = "Shopping Cart";
}

<h1 class="text-dark mb-4">Shopping Cart</h1>

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (!Model.Any())
{
    <div class="card p-5 text-center shadow">
        <div class="mb-3">
            <i class="bi bi-cart-x" style="font-size: 4rem; color: #6c757d;"></i>
        </div>
        <h3 class="text-dark">Your cart is empty</h3>
        <p class="text-muted">Looks like you haven't added anything to your cart yet.</p>
        <div class="mt-3">
            <a asp-action="Store" class="btn btn-primary">Start Shopping</a>
        </div>
    </div>
}
else
{
    <div class="row">
        <div class="col-lg-8">
            <div class="card shadow mb-4">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-light">
                            <tr>
                                <th class="ps-4">Product</th>
                                <th>Manufacturer</th>
                                <th>Price</th>
                                <th>Quantity</th>
                                <th>Total</th>
                                <th class="text-end pe-4">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="ps-4">
                                        <div class="d-flex align-items-center">
                                            @if (!string.IsNullOrEmpty(item.Product.ImageUrl))
                                            {
                                                <img src="@item.Product.ImageUrl" alt="@item.Product.Name" class="rounded me-3" style="width: 50px; height: 50px; object-fit: contain; background: white;">
                                            }
                                            <span class="fw-bold">@item.Product.Name</span>
                                        </div>
                                    </td>
                                    <td><span class="badge bg-secondary">@item.Product.Manufacturer</span></td>
                                    <td>@item.Product.Price $</td>
                                    <td>
                                        <form asp-action="UpdateCartQuantity" method="post" style="width: 80px;">
                                            <input type="hidden" name="cartItemId" value="@item.Id" />
                                            <input type="number" name="quantity" value="@item.Quantity" min="1" onchange="this.form.submit()"
                                                   class="form-control form-control-sm text-center" />
                                        </form>
                                    </td>
                                    <td class="fw-bold text-primary">@(item.Product.Price * item.Quantity) $</td>
                                    <td class="text-end pe-4">
                                        <form asp-action="RemoveFromCart" method="post">
                                            <input type="hidden" name="cartItemId" value="@item.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger">
                                                <i class="bi bi-trash"></i> Remove
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
            <a asp-action="Store" class="btn btn-outline-light">
                <i class="bi bi-arrow-left"></i> Continue Shopping
            </a>
        </div>
        <div class="col-lg-4">
            <div class="card shadow border-info">
                <div class="card-header bg-info text-dark fw-bold">
                    Order Summary
                </div>
                <div class="card-body">
                    <div class="d-flex justify-content-between mb-2">
                        <span>Subtotal</span>
                        <span>@Model.Sum(x => x.Product.Price * x.Quantity) $</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span>Shipping</span>
                        <span class="text-success">Free</span>
                    </div>
                    <hr>
                    <div class="d-flex justify-content-between mb-4">
                        <span class="h5">Grand Total</span>
                        <span class="h5 text-primary">@Model.Sum(x => x.Product.Price * x.Quantity) $</span>
                    </div>
                    <form asp-action="Checkout" method="post">
                        <button type="submit" class="btn btn-primary btn-lg w-100">
                            Proceed to Checkout
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
}