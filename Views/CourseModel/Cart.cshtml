@model IEnumerable<tech_market.Models.CartItem>

@{
    ViewData["Title"] = "Shopping Cart";
}

<h1>Shopping Cart</h1>

@if (!Model.Any())
{
    <div class="alert alert-info">Your cart is empty.</div>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Product</th>
                <th>Manufacturer</th>
                <th>Price</th>
                <th>Quantity</th>
                <th>Total</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Product.Name</td>
                    <td>@item.Product.Manufacturer</td>
                    <td>@item.Product.Price $</td>
                    <td>
                        <form asp-action="UpdateCartQuantity" method="post" class="d-inline-flex">
                            <input type="hidden" name="cartItemId" value="@item.Id" />
                            <input type="number" name="quantity" value="@item.Quantity" min="1" onchange="this.form.submit()"
                                   class="form-control form-control-sm" style="width: 70px;" />
                        </form>
                    </td>
                    <td>@(item.Product.Price * item.Quantity) $</td>
                    <td>
                        <form asp-action="RemoveFromCart" method="post">
                            <input type="hidden" name="cartItemId" value="@item.Id" />
                            <button type="submit" class="btn btn-sm btn-danger">Remove</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <div class="text-end">
        <h3>Grand Total: @Model.Sum(x => x.Product.Price * x.Quantity) $</h3>
        <form asp-action="Checkout" method="post">
            <button type="submit" class="btn btn-primary btn-lg mt-2">Proceed to Checkout</button>
        </form>
    </div>
}

<p class="mt-3">
    <a asp-action="Store" class="btn btn-secondary">Continue Shopping</a>
</p>