@model tech_market.Models.Product

@{
    ViewData["Title"] = "Delete Product";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-6">
        <div class="card shadow border-danger">
            <div class="card-header bg-danger text-white py-3 text-center">
                <i class="bi bi-exclamation-triangle-fill mb-2" style="font-size: 2rem;"></i>
                <h3 class="mb-0">Confirm Deletion</h3>
            </div>
            <div class="card-body p-4 text-center">
                <p class="mb-4">Are you sure you want to permanently delete this product?</p>
                
                <div class="p-3 bg-light text-dark rounded mb-4">
                    <h4 class="fw-bold mb-1">@Model.Name</h4>
                    <span class="badge bg-secondary">@Model.Manufacturer</span>
                    <div class="mt-2 text-primary fw-bold">Price: @Model.Price $</div>
                </div>

                <div class="alert alert-warning small">
                    <i class="bi bi-info-circle me-2"></i>
                    This action cannot be undone. All related data will be removed.
                </div>

                <form asp-action="Delete" class="d-flex justify-content-center gap-3 mt-4">
                    <input type="hidden" asp-for="Id" />
                    <a asp-action="Index" class="btn btn-secondary px-4">Cancel</a>
                    <button type="submit" class="btn btn-danger px-4">
                        <i class="bi bi-trash"></i> Delete Product
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>