@model IEnumerable<tech_market.Models.Product>

@{
    ViewData["Title"] = "Store";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="text-dark">Technology Store</h1>
    <div class="text-muted">Explore our latest gadgets</div>
</div>

<style>
    .product-card {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        border: 1px solid #dee2e6 !important;
    }
    .product-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
        border-color: #0d6efd !important;
    }
    .product-image-container {
        height: 220px;
        background-color: #f8f9fa;
        display: flex;
        align-items: center;
        justify-content: center;
        border-top-left-radius: 4px;
        border-top-right-radius: 4px;
        overflow: hidden;
        padding: 1rem;
    }
    .product-image-container img {
        max-height: 100%;
        width: auto;
        object-fit: contain;
    }
</style>

<div class="row">
    @foreach (var item in Model)
    {
        <div class="col-lg-4 col-md-6 mb-4">
            <div class="card h-100 product-card">
                <div class="product-image-container">
                    @if (!string.IsNullOrEmpty(item.ImageUrl))
                    {
                        <img src="@item.ImageUrl" alt="@item.Name">
                    }
                    else
                    {
                        <div class="text-muted d-flex flex-column align-items-center">
                            <i class="bi bi-image" style="font-size: 3rem;"></i>
                            <span>No Image</span>
                        </div>
                    }
                </div>
                <div class="card-body d-flex flex-column">
                    <div class="mb-2">
                        <span class="badge bg-primary">@item.Manufacturer</span>
                    </div>
                    <h5 class="card-title text-dark mb-2">@item.Name</h5>
                    <p class="card-text text-muted small flex-grow-1">
                        @if (item.Description?.Length > 100)
                        {
                            @(item.Description.Substring(0, 97) + "...")
                        }
                        else
                        {
                            @item.Description
                        }
                    </p>
                    <div class="d-flex justify-content-between align-items-end mt-3">
                        <div>
                            <span class="text-muted small d-block">Price</span>
                            <span class="h4 text-primary mb-0">@item.Price $</span>
                        </div>
                        <div class="text-end">
                            <span class="badge @(item.StockQuantity > 0 ? "bg-success" : "bg-danger")">
                                Stock: @item.StockQuantity
                            </span>
                        </div>
                    </div>
                </div>
                <div class="card-footer bg-white border-top p-3">
                    <div class="row g-2">
                        <div class="col-8">
                            <form asp-action="AddToCart" method="post">
                                <input type="hidden" name="productId" value="@item.Id" />
                                <button type="submit" class="btn btn-primary w-100" @(item.StockQuantity == 0 ? "disabled" : "")>
                                    Add to Cart
                                </button>
                            </form>
                        </div>
                        <div class="col-4">
                            <form asp-action="AddToWishlist" method="post">
                                <input type="hidden" name="productId" value="@item.Id" />
                                <button type="submit" class="btn btn-outline-danger w-100">
                                    <i class="bi bi-heart"></i>
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>