<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - tech_market</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>

<body>
    <header>
        <nav
            class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">tech_market</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        @if (User.Identity.IsAuthenticated)
                        {
                            @if (User.IsInRole("Technician"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-controller="CourseModel" asp-action="Index">Product
                                        Management (CRUD)</a>
                                    </li>
                                }
                                @if (User.IsInRole("Customer"))
                                {
                                    <li class="nav-item">
                                        <a class="nav-link text-dark" asp-controller="CourseModel" asp-action="Store">Store</a>
                                    </li>
                                    <li class="nav-item">
                                        <a class="nav-link text-dark" asp-controller="CourseModel" asp-action="Cart">My Cart</a>
                                    </li>
                                    <li class="nav-item">
                                        <a class="nav-link text-dark" asp-controller="CourseModel"
                                           asp-action="Wishlist">Wishlist</a>
                                    </li>
                                    <li class="nav-item">
                                        <a class="nav-link text-dark" asp-controller="CourseModel"
                                           asp-action="OrderHistory">Orders</a>
                                    </li>
                                }
                            }
                        </ul>
                        <ul class="navbar-nav">
                            @if (User.Identity.IsAuthenticated)
                            {
                                <li class="nav-item">
                                    <span class="nav-link text-info">Hello, @User.Identity.Name
                                        (@User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value)</span>
                                    </li>
                                    <li class="nav-item">
                                        <a class="nav-link text-danger" asp-controller="CourseModel" asp-action="Logout">Logout</a>
                                    </li>
                                }
                        else
                                {
                                    <li class="nav-item">
                                        <a class="nav-link text-dark" asp-controller="CourseModel" asp-action="Login">Login</a>
                                    </li>
                                    <li class="nav-item">
                                        <a class="nav-link text-dark" asp-controller="CourseModel"
                                           asp-action="Register">Register</a>
                                    </li>
                                }
                            </ul>
                        </div>
                    </div>
                </nav>
            </header>
            <div class="container">
                <main role="main" class="pb-3">
                    @RenderBody()
                </main>
            </div>

            <script src="~/lib/jquery/dist/jquery.min.js"></script>
            <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
            <script src="~/js/site.js" asp-append-version="true"></script>
            @await RenderSectionAsync("Scripts", required: false)
        </body>

    </html>